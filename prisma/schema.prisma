generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String               @id @default(cuid())
  email          String               @unique
  passwordHash   String?
  role           UserRole             @default(STUDENT)
  createdAt      DateTime             @default(now())
  authAccounts   AuthAccount[]
  analyticsEvents AnalyticsEvent[]
  accesses       CourseAccess[]
  lessonProgress LessonProgress[]
  taskAttempts   TaskAttempt[]
  taskProgress   TaskProgress[]
  chatSessions   ChatSession[]
  resetTokens    PasswordResetToken[]
  payments       PaymentIntent[]
  uploads        UserUpload[]
  aiAnalyses     AiSolutionAnalysis[]
  wallet         Wallet?
  walletTransactions WalletTransaction[]
  loyaltyAccount LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]
  loyaltyPointBuckets LoyaltyPointBucket[]
  adminAuditLogs AdminAuditLog[]      @relation("AdminAuditActor")
  errorLogs      ServiceError[]
  paymentEvents  PaymentEvent[]
  ownedCourses   CustomCourse[]       @relation("TutorOwnedCourses")

  @@index([role, createdAt])
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

model CourseAccess {
  id         String     @id @default(cuid())
  userId     String
  courseId   String
  accessType AccessType @default(TRIAL)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, expiresAt])
  @@index([userId, expiresAt, createdAt])
  @@index([courseId, userId])
}

model LessonProgress {
  id              String         @id @default(cuid())
  userId          String
  lessonId        String
  status          ProgressStatus @default(NOT_STARTED)
  lastPositionSec Int            @default(0)
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model TaskAttempt {
  id         String   @id @default(cuid())
  userId     String
  taskId     String
  answerText String
  isCorrect  Boolean?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, taskId])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  chatType  ChatType
  lessonId  String?
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, chatType, lessonId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  chatId    String
  role      ChatRole
  content   String
  mode      String      @default("default")
  createdAt DateTime    @default(now())
  chat      ChatSession @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model CustomCourse {
  id          String          @id
  ownerId     String?
  title       String
  description String
  subject     Subject
  createdAt   DateTime        @default(now())
  owner       User?           @relation("TutorOwnedCourses", fields: [ownerId], references: [id], onDelete: SetNull)
  sections    CustomSection[]

  @@index([ownerId])
  @@index([ownerId, createdAt])
  @@index([subject])
}

model CustomSection {
  id        String         @id
  courseId  String
  title     String
  createdAt DateTime       @default(now())
  course    CustomCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   CustomLesson[]

  @@index([courseId])
  @@index([courseId, createdAt])
}

model CustomLesson {
  id          String       @id
  sectionId   String
  title       String
  description String
  videoUrl    String
  createdAt   DateTime     @default(now())
  section     CustomSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  tasks       CustomTask[]

  @@index([sectionId])
  @@index([sectionId, createdAt])
}

model CustomTask {
  id        String    @id
  lessonId  String
  type      TaskType
  status    TaskStatus @default(PUBLISHED)
  question  String
  options   String?
  answer    String
  solution  String
  difficulty Int      @default(2)
  topicTags String?
  exemplarSolution String?
  evaluationCriteria String?
  createdAt DateTime  @default(now())
  lesson    CustomLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([lessonId, status, createdAt])
  @@index([status, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PaymentIntent {
  id                String        @id @default(cuid())
  userId            String
  planId            String
  amountCents       Int
  currency          String        @default("RUB")
  status            PaymentStatus @default(CREATED)
  provider          String        @default("mock")
  providerPaymentId String?
  idempotencyKey    String?
  checkoutToken     String        @unique
  metadata          String?
  failedAt          DateTime?
  canceledAt        DateTime?
  failureReason     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paidAt            DateTime?
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events            PaymentEvent[]

  @@unique([userId, idempotencyKey])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([userId, paidAt])
  @@index([userId, paidAt, createdAt])
  @@index([userId, status, paidAt])
  @@index([planId, createdAt])
  @@index([status, createdAt])
  @@index([provider, createdAt])
  @@index([paidAt])
}

model PaymentEvent {
  id             String        @id @default(cuid())
  paymentId      String
  userId         String
  provider       String
  providerEventId String
  status         PaymentStatus
  payload        Json?
  createdAt      DateTime      @default(now())
  payment        PaymentIntent  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerEventId])
  @@index([paymentId, createdAt])
  @@index([userId, createdAt])
}

model TaskProgress {
  id               String           @id @default(cuid())
  userId           String
  taskId           String
  lessonId         String
  status           ProgressStatus   @default(NOT_STARTED)
  scorePercent     Int?
  attemptsCount    Int              @default(0)
  firstCompletedAt DateTime?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId, lessonId, updatedAt])
  @@index([lessonId, status])
}

model Wallet {
  id             String              @id @default(cuid())
  userId         String              @unique
  balanceCents   Int                 @default(0)
  currency       String              @default("RUB")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   WalletTransaction[]
}

model WalletTransaction {
  id               String                @id @default(cuid())
  walletId         String
  userId           String
  direction        WalletDirection
  operationType    WalletOperationType
  amountCents      Int
  balanceBefore    Int
  balanceAfter     Int
  paymentIntentId  String?
  idempotencyKey   String?
  metadata         Json?
  createdAt        DateTime              @default(now())
  wallet           Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([userId, operationType, createdAt])
  @@index([walletId, createdAt])
  @@index([operationType, createdAt])
  @@index([paymentIntentId])
}

model LoyaltyAccount {
  id                    String             @id @default(cuid())
  userId                String             @unique
  pointsBalance         Int                @default(0)
  lifetimeEarnedPoints  Int                @default(0)
  lifetimeRedeemedPoints Int               @default(0)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          LoyaltyTransaction[]
  pointBuckets          LoyaltyPointBucket[]
}

model LoyaltyTransaction {
  id              String           @id @default(cuid())
  loyaltyAccountId String
  userId          String
  direction       LoyaltyDirection
  reason          LoyaltyReason
  points          Int
  balanceBefore   Int
  balanceAfter    Int
  courseId        String?
  paymentIntentId String?
  idempotencyKey  String?
  metadata        Json?
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())
  loyaltyAccount  LoyaltyAccount   @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceBuckets   LoyaltyPointBucket[] @relation("LoyaltyBucketSource")

  @@unique([userId, idempotencyKey])
  @@unique([userId, reason, courseId])
  @@index([userId, createdAt])
  @@index([userId, reason, createdAt])
  @@index([loyaltyAccountId, createdAt])
  @@index([courseId])
  @@index([paymentIntentId])
}

model LoyaltyPointBucket {
  id                  String            @id @default(cuid())
  loyaltyAccountId    String
  userId              String
  sourceTransactionId String?
  totalPoints         Int
  remainingPoints     Int
  expiresAt           DateTime
  createdAt           DateTime          @default(now())
  loyaltyAccount      LoyaltyAccount    @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceTransaction   LoyaltyTransaction? @relation("LoyaltyBucketSource", fields: [sourceTransactionId], references: [id], onDelete: SetNull)

  @@index([userId, expiresAt])
  @@index([loyaltyAccountId, expiresAt])
  @@index([sourceTransactionId])
}

model UserUpload {
  id           String   @id @default(cuid())
  userId       String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  extractedText String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model LessonKnowledge {
  id            String   @id @default(cuid())
  lessonId      String   @unique
  originalName  String
  mimeType      String
  storagePath   String
  extractedText String
  summary       String?
  pageCount     Int?
  textChars     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AiSolutionAnalysis {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String?
  taskId      String?
  mode        String   @default("default")
  status      String   @default("completed")
  model       String?
  latencyMs   Int?
  input       Json
  result      Json?
  error       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([taskId, createdAt])
  @@index([lessonId, createdAt])
  @@index([status, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, latencyMs, createdAt])
}

model DatasetFile {
  id           String   @id @default(cuid())
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  processingStatus DatasetProcessingStatus @default(UPLOADED)
  extractedText String?
  summary      String?
  pageCount    Int?
  textChars    Int      @default(0)
  processingError String?
  processedAt  DateTime?
  createdAt    DateTime @default(now())
  chunks       DatasetTextChunk[]

  @@index([createdAt])
  @@index([processingStatus, createdAt])
}

model DatasetTextChunk {
  id            String   @id @default(cuid())
  datasetFileId String
  chunkIndex    Int
  content       String
  charCount     Int
  createdAt     DateTime @default(now())
  datasetFile   DatasetFile @relation(fields: [datasetFileId], references: [id], onDelete: Cascade)

  @@index([datasetFileId, chunkIndex])
  @@unique([datasetFileId, chunkIndex])
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  publishedAt DateTime?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, publishedAt])
  @@index([publishedAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventName String
  userId    String?
  path      String?
  payload   Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@index([userId, eventName, createdAt])
  @@index([createdAt])
  @@index([eventName, userId, createdAt])
  @@index([path, createdAt])
}

model DailyMetricAggregate {
  id                 String   @id @default(cuid())
  day                DateTime @unique
  dau                Int      @default(0)
  wau                Int      @default(0)
  registrations      Int      @default(0)
  paidUsers          Int      @default(0)
  paymentConversion  Float    @default(0)
  retainedD1         Int      @default(0)
  retainedD7         Int      @default(0)
  aiChatMessages     Int      @default(0)
  revenueCents       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([day])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  adminUser   User     @relation("AdminAuditActor", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([entityType, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}

model ServiceError {
  id            String   @id @default(cuid())
  requestId     String?
  route         String?
  level         LogLevel @default(ERROR)
  message       String
  details       Json?
  stack         String?
  occurredAt    DateTime @default(now())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([level, occurredAt])
  @@index([route, occurredAt])
  @@index([requestId])
}

model JobQueue {
  id             String    @id @default(cuid())
  jobType        String
  payload        Json
  status         JobStatus @default(PENDING)
  runAt          DateTime  @default(now())
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  lastError      String?
  idempotencyKey String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  @@unique([jobType, idempotencyKey])
  @@index([status, runAt])
  @@index([jobType, createdAt])
}

enum UserRole {
  STUDENT
  TUTOR
  ADMIN
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ChatType {
  LESSON
  GLOBAL
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AccessType {
  TRIAL
  SUBSCRIPTION
  PURCHASE
}

enum Subject {
  math
  physics
}

enum TaskType {
  numeric
  choice
}

enum TaskStatus {
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum DatasetProcessingStatus {
  UPLOADED
  PARSED
  PROCESSING
  READY
  FAILED
}

enum PaymentStatus {
  CREATED
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
}

enum WalletDirection {
  CREDIT
  DEBIT
}

enum WalletOperationType {
  TOPUP
  PURCHASE
  REFUND
  MANUAL_ADJUSTMENT
}

enum LoyaltyDirection {
  CREDIT
  DEBIT
}

enum LoyaltyReason {
  COURSE_COMPLETION
  DISCOUNT_REDEEM
  DISCOUNT_ROLLBACK
  EXPIRATION
  MANUAL_ADJUSTMENT
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum JobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}
